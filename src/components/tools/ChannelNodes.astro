---
// Channel Nodes — node editor for remapping image channels.
// CSS and JS loaded from public/tools/channel-nodes/.
---

<div class="channel-nodes">
  <h2>Channel Nodes</h2>
  <p class="description">
    Route image channels by dragging a dot from <b>Source Image</b> to <b>Output</b>.
    Click a connection to remove it.
  </p>

  <div class="panels" id="cn-panels">
    <!-- INPUT -->
    <div class="panel">
      <div class="panel-label">Source Image</div>
      <div class="panel-body drop-zone" id="cn-input-zone">
        <input type="file" id="cn-upload" accept="image/*" />
        <canvas id="cn-input-canvas"></canvas>
        <div class="zone-placeholder" id="cn-input-placeholder">
          Click or drop an image
        </div>
        <!-- Dots are inside panel-body so they stay centred on the image area. -->
        <div class="cn-dots cn-dots-out">
          <div class="cn-dot red" data-side="in" data-channel="r" title="Red"></div>
          <div class="cn-dot green" data-side="in" data-channel="g" title="Green"></div>
          <div class="cn-dot blue" data-side="in" data-channel="b" title="Blue"></div>
        </div>
      </div>
    </div>

    <!-- OUTPUT -->
    <div class="panel">
      <div class="panel-label">Output</div>
      <div class="panel-body drop-zone drop-zone-readonly">
        <canvas id="cn-output-canvas"></canvas>
        <div class="preview-badge" id="cn-preview-badge">Preview</div>
        <div class="cn-dots cn-dots-in">
          <div class="cn-dot red" data-side="out" data-channel="r" title="Red"></div>
          <div class="cn-dot green" data-side="out" data-channel="g" title="Green"></div>
          <div class="cn-dot blue" data-side="out" data-channel="b" title="Blue"></div>
        </div>
      </div>
    </div>

    <svg id="cn-svg" width="100%" height="100%"></svg>
  </div>

  <div class="strength">
    <span class="strength-title">Channel Strength</span>
    <div class="strength-row">
      <label class="r" for="cn-str-r">R</label>
      <input type="range" id="cn-str-r" min="0" max="2" step="0.01" value="1" />
      <output id="cn-str-r-out">1.00</output>
    </div>
    <div class="strength-row">
      <label class="g" for="cn-str-g">G</label>
      <input type="range" id="cn-str-g" min="0" max="2" step="0.01" value="1" />
      <output id="cn-str-g-out">1.00</output>
    </div>
    <div class="strength-row">
      <label class="b" for="cn-str-b">B</label>
      <input type="range" id="cn-str-b" min="0" max="2" step="0.01" value="1" />
      <output id="cn-str-b-out">1.00</output>
    </div>
    <button id="cn-reset-strength" class="strength-reset" title="Reset strengths to 1">Reset</button>
  </div>

  <div class="actions">
    <button id="cn-reset">Reset</button>
  </div>
  <div class="status" id="cn-status"></div>
</div>
