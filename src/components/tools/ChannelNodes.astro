---
// Channel Nodes tool - node editor for remapping image channels.
// Drag from an input channel dot to an output channel dot to remap it.
---

<h2>Channel Nodes</h2>
<p>Click the input box to load an image. Drag from an input channel dot to an output channel dot to remap it. Click a connection to remove it.</p>

<div class="cn-workspace">
  <div class="cn-node cn-input" id="cn-input">
    <h3>Input</h3>
    <label class="cn-canvas-wrap" id="cn-input-wrap">
      <canvas id="cn-input-canvas" width="480" height="320"></canvas>
      <span class="cn-placeholder" id="cn-placeholder">Click to load image</span>
    </label>
    <div class="cn-dots cn-dots-out">
      <div class="cn-dot red" data-side="in" data-channel="r" title="Red"></div>
      <div class="cn-dot green" data-side="in" data-channel="g" title="Green"></div>
      <div class="cn-dot blue" data-side="in" data-channel="b" title="Blue"></div>
    </div>
  </div>

  <div class="cn-node cn-output" id="cn-output">
    <h3>Output</h3>
    <div class="cn-canvas-wrap">
      <canvas id="cn-output-canvas" width="480" height="320"></canvas>
    </div>
    <div class="cn-dots cn-dots-in">
      <div class="cn-dot red" data-side="out" data-channel="r" title="Red"></div>
      <div class="cn-dot green" data-side="out" data-channel="g" title="Green"></div>
      <div class="cn-dot blue" data-side="out" data-channel="b" title="Blue"></div>
    </div>
  </div>

  <svg id="cn-svg" width="100%" height="100%"></svg>
</div>

<input type="file" id="cn-upload" accept="image/*" hidden />

<style>
  .cn-workspace {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: 12rem;
    margin-top: 1rem;
    min-height: 420px;
  }

  .cn-node {
    position: relative;
    background: var(--bg-sidebar);
    border: 1px solid var(--border);
    padding: 0.75rem;
    width: 480px;
  }

  .cn-node h3 {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
  }

  .cn-canvas-wrap {
    display: block;
    position: relative;
    cursor: pointer;
    background: var(--border);
  }

  .cn-canvas-wrap canvas {
    display: block;
    width: 100%;
    height: auto;
  }

  .cn-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    pointer-events: none;
  }

  .cn-dots {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cn-dots-out {
    right: -12px;
  }
  .cn-dots-in {
    left: -12px;
  }

  .cn-dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 1px #000;
    cursor: crosshair;
  }
  .cn-dot.red { background: #c0392b; }
  .cn-dot.green { background: #27ae60; }
  .cn-dot.blue { background: #2980b9; }

  #cn-svg {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
  }
</style>

<script>
  const inputCanvas = document.getElementById('cn-input-canvas') as HTMLCanvasElement;
  const outputCanvas = document.getElementById('cn-output-canvas') as HTMLCanvasElement;
  const ctxIn = inputCanvas.getContext('2d')!;
  const ctxOut = outputCanvas.getContext('2d')!;
  const svg = document.getElementById('cn-svg') as unknown as SVGSVGElement;
  const fileInput = document.getElementById('cn-upload') as HTMLInputElement;
  const placeholder = document.getElementById('cn-placeholder') as HTMLElement;
  const inputWrap = document.getElementById('cn-input-wrap') as HTMLElement;
  const workspace = document.querySelector('.cn-workspace') as HTMLElement;

  let originalData: ImageData | null = null;
  let connections: Array<{ from: HTMLElement; to: HTMLElement }> = [];
  let dragging: { dot: HTMLElement } | null = null;
  let tempLine: SVGPathElement | null = null;

  function syncSvg() {
    const rect = workspace.getBoundingClientRect();
    svg.setAttribute('width', String(rect.width));
    svg.setAttribute('height', String(rect.height));
    svg.style.width = rect.width + 'px';
    svg.style.height = rect.height + 'px';
  }

  function getDotCenter(dot: HTMLElement): { x: number; y: number } {
    const dotRect = dot.getBoundingClientRect();
    const svgRect = svg.getBoundingClientRect();
    return {
      x: dotRect.left + dotRect.width / 2 - svgRect.left,
      y: dotRect.top + dotRect.height / 2 - svgRect.top,
    };
  }

  function linePath(x1: number, y1: number, x2: number, y2: number): string {
    const dx = Math.max(40, Math.abs(x2 - x1) * 0.5);
    return `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
  }

  function dotKey(dot: HTMLElement): string {
    return `${dot.dataset.side}-${dot.dataset.channel}`;
  }

  function renderConnections() {
    syncSvg();
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    connections.forEach((conn) => {
      const a = getDotCenter(conn.from);
      const b = getDotCenter(conn.to);
      const d = linePath(a.x, a.y, b.x, b.y);

      // Wide invisible hit area for easy clicking.
      const hit = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      hit.setAttribute('d', d);
      hit.setAttribute('stroke', 'transparent');
      hit.setAttribute('stroke-width', '16');
      hit.setAttribute('fill', 'none');
      hit.setAttribute('pointer-events', 'stroke');
      hit.style.cursor = 'pointer';
      hit.addEventListener('click', (e) => {
        e.stopPropagation();
        connections = connections.filter((c) => c !== conn);
        renderConnections();
        applyChannels();
      });
      svg.appendChild(hit);

      // Visible line on top.
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', d);
      path.setAttribute('stroke', '#222');
      path.setAttribute('stroke-width', '3');
      path.setAttribute('fill', 'none');
      path.style.pointerEvents = 'none';
      svg.appendChild(path);
    });
  }

  function loadImage(file: File) {
    const img = new Image();
    img.onload = () => {
      inputCanvas.width = img.width;
      inputCanvas.height = img.height;
      outputCanvas.width = img.width;
      outputCanvas.height = img.height;
      ctxIn.drawImage(img, 0, 0);
      originalData = ctxIn.getImageData(0, 0, inputCanvas.width, inputCanvas.height);
      placeholder.style.display = 'none';
      applyChannels();
      requestAnimationFrame(renderConnections);
    };
    img.src = URL.createObjectURL(file);
  }

  function applyChannels() {
    if (!originalData) return;

    const w = originalData.width;
    const h = originalData.height;
    const src = originalData.data;
    const out = ctxOut.createImageData(w, h);
    const dst = out.data;

    // No connections → blank output.
    if (connections.length === 0) {
      ctxOut.clearRect(0, 0, w, h);
      ctxOut.putImageData(out, 0, 0);
      return;
    }

    // Each output channel is sourced from whichever input channel is
    // routed to it (Blender-style). Unrouted outputs stay at 0.
    const chIndex = { r: 0, g: 1, b: 2 } as const;
    const map: Record<'r' | 'g' | 'b', 'r' | 'g' | 'b' | null> = {
      r: null, g: null, b: null,
    };

    for (const conn of connections) {
      if (conn.from.dataset.side === 'in' && conn.to.dataset.side === 'out') {
        map[conn.to.dataset.channel as 'r' | 'g' | 'b'] =
          conn.from.dataset.channel as 'r' | 'g' | 'b';
      }
    }

    for (let i = 0; i < src.length; i += 4) {
      dst[i] = map.r !== null ? src[i + chIndex[map.r]] : 0;
      dst[i + 1] = map.g !== null ? src[i + chIndex[map.g]] : 0;
      dst[i + 2] = map.b !== null ? src[i + chIndex[map.b]] : 0;
      dst[i + 3] = src[i + 3];
    }

    ctxOut.putImageData(out, 0, 0);
  }

  // Open file picker when the input canvas is clicked.
  inputWrap.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) loadImage(file);
  });

  // Drag from a dot. Use document-level pointermove/up so dragging
  // works even when the pointer leaves the dot.
  document.querySelectorAll<HTMLElement>('.cn-dot').forEach((dot) => {
    dot.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      dragging = { dot };
      syncSvg();

      tempLine = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      tempLine.setAttribute('stroke', '#888');
      tempLine.setAttribute('stroke-width', '2');
      tempLine.setAttribute('stroke-dasharray', '4 3');
      tempLine.setAttribute('fill', 'none');
      svg.appendChild(tempLine);
    });
  });

  document.addEventListener('pointermove', (e) => {
    if (!dragging || !tempLine) return;
    const start = getDotCenter(dragging.dot);
    const svgRect = svg.getBoundingClientRect();
    const end = { x: e.clientX - svgRect.left, y: e.clientY - svgRect.top };
    tempLine.setAttribute('d', linePath(start.x, start.y, end.x, end.y));
  });

  document.addEventListener('pointerup', (e) => {
    if (!dragging || !tempLine) return;
    tempLine.remove();
    tempLine = null;

    const target = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null;
    if (
      target &&
      target.classList.contains('cn-dot') &&
      target !== dragging.dot &&
      target.dataset.side !== dragging.dot.dataset.side
    ) {
      const fromSide = dragging.dot.dataset.side!;
      const fromKey = dotKey(dragging.dot);
      const toKey = dotKey(target);

      if (fromSide === 'out') {
        // Dragged out -> in: flip so connections always go in -> out.
        connections = connections.filter(
          (c) => !(dotKey(c.from) === toKey && dotKey(c.to) === fromKey)
        );
        connections.push({ from: target, to: dragging.dot });
      } else {
        connections = connections.filter(
          (c) => !(dotKey(c.from) === fromKey && dotKey(c.to) === toKey)
        );
        connections.push({ from: dragging.dot, to: target });
      }
      renderConnections();
      applyChannels();
    }

    dragging = null;
  });

  // Re-render lines on resize.
  window.addEventListener('resize', renderConnections);
</script>
