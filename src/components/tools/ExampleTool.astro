---
// EXAMPLE TOOL — Reference template for building new tools.
//
// Layout pattern:
//   [ Input ]  [ Main Control ]  [ Output ]
//            [ Settings below ]
//
// To create a new tool:
//   1. Copy this file and rename it (e.g. MyTool.astro)
//   2. Copy the <style> block and rename the class (e.g. .my-tool)
//   3. Update the HTML structure below
//   4. Add a page in src/pages/ that imports your component
//   5. Add the tool to the sidebar in BaseLayout.astro
//
// CSS is scoped via <style> — Astro automatically prefixes it.
// For heavier CSS, use a separate file in public/tools/<name>/ and
// load it via <link slot="head"> in the page component.
---

<div class="example-tool">
  <h2>Example Tool</h2>
  <p class="description">A reference layout for building new tools. Three panels across, settings below.</p>

  <div class="panels">
    <!-- INPUT PANEL: file upload, drag-and-drop, or source selector -->
    <div class="panel panel-input">
      <div class="panel-header">
        <button class="panel-btn" title="Fullscreen (placeholder)">⛶</button>
        <span>Input</span>
        <button class="panel-btn" title="Clear (placeholder)">✕</button>
      </div>
      <div class="panel-body">
        <p>Source / upload area</p>
      </div>
    </div>

    <!-- OPTIONS PANEL: the primary tool controls -->
    <div class="panel panel-options">
      <div class="panel-label">Options</div>
      <div class="panel-body">
        <div class="setting">
          <label>Option A</label>
          <select>
            <option>Option 1</option>
            <option>Option 2</option>
          </select>
        </div>
        <div class="setting">
          <label>Option B</label>
          <input type="range" min="0" max="100" value="50" />
        </div>
      </div>
    </div>

    <!-- OUTPUT PANEL: preview or result -->
    <div class="panel panel-output">
      <div class="panel-header">
        <button class="panel-btn" title="Fullscreen (placeholder)">⛶</button>
        <span>Output</span>
        <button class="panel-btn" title="Download (placeholder)">↓</button>
      </div>
      <div class="panel-body">
        <p>Result / preview area</p>
      </div>
    </div>
  </div>

  <!-- SETTINGS BAR: secondary options, sliders, toggles -->
  <div class="settings">
    <div class="setting">
      <label>Setting A</label>
      <input type="range" min="0" max="100" value="50" />
    </div>
    <div class="setting">
      <label>Setting B</label>
      <input type="range" min="0" max="100" value="50" />
    </div>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="actions">
    <button>Run</button>
    <button class="reset-btn">Reset</button>
  </div>
</div>

<style>
  /* Scoped to .example-tool — no conflicts with layout or other tools.
     Inspired by the Dither tool styling. */

  .example-tool {
    --example-accent: #cc0000;
    --example-bg: #eee;
    --example-border: #aaa;
    --example-muted: #666;

    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .example-tool h2 {
    margin: 0;
  }

  .example-tool .description {
    margin: 0;
    color: var(--example-muted);
    font-size: 0.85rem;
  }

  /* Three-panel layout */
  .example-tool .panels {
    display: flex;
    gap: 16px;
    width: 100%;
    align-items: stretch;
  }

  .example-tool .panel {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  /* Input and output panels are wider; control panel is narrower. */
  .example-tool .panel-input,
  .example-tool .panel-output {
    flex: 2 1 0;
  }

  .example-tool .panel-options {
    flex: 1 1 0;
  }

  /* Panel headers and labels share the same height. */
  .example-tool .panel-label,
  .example-tool .panel-header {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-height: 40px;
    box-sizing: border-box;
    padding: 6px 12px;
    background: var(--example-border);
    color: #fff;
    text-align: center;
  }

  .example-tool .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .example-tool .panel-label {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .example-tool .panel-header span {
    flex: 1;
    text-align: center;
  }

  .example-tool .panel-btn {
    width: 28px;
    height: 28px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    border: 1px solid #fff;
    background: transparent;
    color: #fff;
    line-height: 1;
  }

  .example-tool .panel-btn:hover {
    background: #fff;
    color: var(--example-border);
  }

  .example-tool .panel-body {
    background: var(--example-bg);
    border: 1px solid var(--example-border);
    border-top: none;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 3;
    max-height: 70vh;
    padding: 16px;
    color: #888;
    font-size: 0.9rem;
  }

  /* Image-style panels keep their aspect ratio and do not stretch. */
  .example-tool .panel-input .panel-body,
  .example-tool .panel-output .panel-body {
    flex: 0 0 auto;
  }

  /* Options panel stretches to match image panel height. */
  .example-tool .panel-options .panel-body {
    flex: 1;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 12px;
    padding: 12px;
    aspect-ratio: auto;
  }

  /* Settings bar below panels */
  .example-tool .settings {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    background: var(--example-bg);
    border: 1px solid var(--example-border);
    padding: 16px;
  }

  .example-tool .setting {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    min-width: 160px;
  }

  .example-tool .setting label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .example-tool .setting select,
  .example-tool .setting input[type="range"] {
    width: 100%;
  }

  .example-tool .setting select {
    padding: 6px 8px;
    font-size: 0.85rem;
    border: 2px solid #111;
    background: #fff;
  }

  .example-tool .setting input[type="range"] {
    accent-color: var(--example-accent);
  }

  /* Action buttons */
  .example-tool .actions {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }

  .example-tool button {
    padding: 8px 24px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    border: 2px solid #111;
    background: var(--example-accent);
    color: #fff;
  }

  .example-tool button:hover {
    background: #aa0000;
  }

  .example-tool .actions .reset-btn {
    padding: 4px 12px;
    font-size: 0.7rem;
    background: #fff;
    color: #111;
  }

  .example-tool .actions .reset-btn:hover {
    background: #f5f5f5;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .example-tool .panels {
      flex-direction: column;
    }
  }
</style>
