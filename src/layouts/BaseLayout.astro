---
// Shared layout: thin header, left sidebar, main content area.
// Used by every page in the app. Do not add per-page layouts.

const { title = 'Photo Edit Site' } = Astro.props;

// Add new tools here. The href is relative to the base path.
// Rendered links prepend import.meta.env.BASE_URL automatically.
const tools = [
  { name: 'Example Tool', path: 'editor/' },
  { name: 'Pixelate', path: 'pixelate/' },
  { name: 'Channel Nodes', path: 'channel-nodes/' },
  { name: 'Dither', path: 'dither/' },
];

// Current path for sidebar active-state highlighting.
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon.ico`} sizes="any" />
    <title>{title}</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
    <slot name="head" />
  </head>
  <body>
    <div class="app-shell">
      <header class="app-header">
        <span>Photo Edit Site</span>
      </header>

      <aside class="app-sidebar">
        <nav aria-label="Tools">
          <ul class="tool-list">
            <li>
              <a href={base} aria-current={currentPath === base ? 'page' : undefined}>Home</a>
            </li>
            {tools.map((tool) => {
              const href = `${base}${tool.path}`;
              return (
                <li>
                  <a href={href} aria-current={currentPath.startsWith(href) ? 'page' : undefined}>
                    {tool.name}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <main class="app-main">
        <slot />
      </main>
    </div>
  </body>
</html>
