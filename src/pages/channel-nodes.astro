---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChannelNodes from '../components/tools/ChannelNodes.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Channel Nodes | Photo Edit Site">
  <link slot="head" rel="stylesheet" href={`${base}tools/channel-nodes/styles.css`} />

  <ChannelNodes />

  <script src={`${base}tools/channel-nodes/engine.js`} data-base={base} defer></script>
</BaseLayout>
