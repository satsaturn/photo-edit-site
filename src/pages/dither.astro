---
import BaseLayout from '../layouts/BaseLayout.astro';
import DitherTool from '../components/tools/DitherTool.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Dither | Photo Edit Site">
  <link slot="head" rel="stylesheet" href={`${base}tools/dither/styles.css`} />

  <DitherTool />

  <script src={`${base}tools/shared/palette.js`} defer></script>
  <script src={`${base}tools/dither/engine.js`} defer></script>
</BaseLayout>
